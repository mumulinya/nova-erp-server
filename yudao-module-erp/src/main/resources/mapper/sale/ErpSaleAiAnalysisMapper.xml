<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.iocoder.yudao.module.erp.dal.mysql.sale.ErpSaleAiAnalysisMapper">

    <!-- жќ©?ж¶“оЃ…ж№Ђе§Јеї”ж№Ђй–їв‚¬йЌћо†Ѕв‚¬е©љо–‚йЌњеІѓо…№йЌ—ж›џжљџ -->
    <select id="selectMonthlyTrend" resultType="java.util.Map">
        SELECT
            DATE_FORMAT(o.order_time, '%Y-%m') AS month,
            IFNULL(SUM(o.total_price), 0) AS amount,
            COUNT(o.id) AS orderCount
        FROM erp_sale_order o
        WHERE o.deleted = 0
          AND o.order_time &gt;= #{startTime}
          AND o.order_time &lt;= #{endTime}
        GROUP BY DATE_FORMAT(o.order_time, '%Y-%m')
        ORDER BY month ASC
    </select>

    <!-- жќ©?0жѕ¶в•…ж”ўйЌћо‡Ђо–‚TOP3жµњСѓжђ§ -->
    <select id="selectTopProducts" resultType="java.util.Map">
        SELECT
            p.name AS productName,
            SUM(i.count) AS totalCount,
            SUM(i.total_price) AS totalAmount
        FROM erp_sale_order_items i
        INNER JOIN erp_sale_order o ON i.order_id = o.id
        INNER JOIN erp_product p ON i.product_id = p.id
        WHERE i.deleted = 0 AND o.deleted = 0 AND p.deleted = 0
          AND o.order_time &gt;= #{startTime}
          AND o.order_time &lt;= #{endTime}
        GROUP BY p.id, p.name
        ORDER BY totalAmount DESC
        LIMIT 3
    </select>

    <!-- жќ©?0жѕ¶в•…ж”ўйЌћо‡Ђо–‚TOP3зЂ№г€Ўеџ› -->
    <select id="selectTopCustomers" resultType="java.util.Map">
        SELECT
            c.name AS customerName,
            COUNT(o.id) AS orderCount,
            SUM(o.total_price) AS totalAmount
        FROM erp_sale_order o
        INNER JOIN erp_customer c ON o.customer_id = c.id
        WHERE o.deleted = 0 AND c.deleted = 0
          AND o.order_time &gt;= #{startTime}
          AND o.order_time &lt;= #{endTime}
        GROUP BY c.id, c.name
        ORDER BY totalAmount DESC
        LIMIT 3
    </select>

</mapper>
